# Server
SECUREAUTHX_SERVER_PORT=8080
SECUREAUTHX_PROFILE=local

# PostgreSQL
SECUREAUTHX_POSTGRES_HOST=postgres
SECUREAUTHX_POSTGRES_PORT=5432
SECUREAUTHX_POSTGRES_DB=secureauthx
SECUREAUTHX_POSTGRES_USER=secureauthx
SECUREAUTHX_POSTGRES_PASSWORD=change-this-local-password
SECUREAUTHX_DB_MAX_POOL_SIZE=10
SECUREAUTHX_DB_MIN_IDLE=2
SECUREAUTHX_DB_CONNECTION_TIMEOUT_MS=30000
SECUREAUTHX_DB_VALIDATION_TIMEOUT_MS=5000
SECUREAUTHX_DB_MAX_LIFETIME_MS=1800000
SECUREAUTHX_DB_LEAK_DETECTION_THRESHOLD_MS=60000

# Redis
SECUREAUTHX_REDIS_HOST=redis
SECUREAUTHX_REDIS_PORT=6379
SECUREAUTHX_REDIS_PASSWORD=change-this-local-redis-password
SECUREAUTHX_REDIS_TIMEOUT=2s

# JWT
SECUREAUTHX_JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
SECUREAUTHX_JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7
# SECUREAUTHX_JWT_PRIVATE_KEY=base64-encoded-pkcs8-private-key
# SECUREAUTHX_JWT_PUBLIC_KEY=base64-encoded-x509-public-key

# Rate Limiting
SECUREAUTHX_RATE_LIMITING_ENABLED=false
SECUREAUTHX_RATE_LIMIT_DEFAULT_RPM=60
SECUREAUTHX_RATE_LIMIT_DEFAULT_RPH=1000

# CORS
SECUREAUTHX_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
SECUREAUTHX_LOG_LEVEL=INFO
SECUREAUTHX_APP_LOG_LEVEL=INFO
SECUREAUTHX_SECURITY_LOG_LEVEL=INFO
SECUREAUTHX_SPRING_WEB_LOG_LEVEL=INFO
SECUREAUTHX_HIBERNATE_SQL_LOG_LEVEL=WARN

# Tomcat (production)
SECUREAUTHX_TOMCAT_MAX_THREADS=200
SECUREAUTHX_TOMCAT_MIN_SPARE=10
SECUREAUTHX_TOMCAT_CONNECTION_TIMEOUT=5000
SECUREAUTHX_TOMCAT_MAX_CONNECTIONS=10000
SECUREAUTHX_TOMCAT_ACCEPT_COUNT=100
